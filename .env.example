# Required: path to directory containing docker-compose.yml with ModSecurity service
WAF_COMPOSE_DIR=/path/to/your/compose/dir

# Optional: domain for WAF test requests (default: https://localhost)
WAF_DOMAIN=https://your-domain.com

# Optional: grep pattern to find the ModSecurity container (default: modsecurity)
WAF_CONTAINER_PATTERN=modsecurity

# Optional: CRS exclusions file relative to compose dir
WAF_EXCLUSIONS_FILE=modsecurity/REQUEST-900-EXCLUSION-RULES-BEFORE-CRS.conf

# Optional: docker compose filename (default: docker-compose.yml)
WAF_COMPOSE_FILE=docker-compose.yml

# Optional: ipinfo.io token for IP geolocation enrichment
IPINFO_TOKEN=

# Optional: enable debug logging (set to any value)
WAF_DEBUG=
